{
  "name": "the-mosaical-hololtih",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "bootstrap": "corepack pnpm --dir apps/api install --frozen-lockfile && npm run prisma:generate:api",
    "bootstrap:web": "corepack pnpm install --no-frozen-lockfile --filter @tmh/web... && npm run prisma:generate:api",
    "dev:api": "corepack pnpm --dir apps/api start:dev",
    "dev:web": "corepack pnpm --filter @tmh/web dev",
    "start:api": "corepack pnpm --dir apps/api start:prod",
    "start:web": "corepack pnpm --filter @tmh/web start",
    "prisma:generate:api": "corepack pnpm --dir apps/api prisma:generate",
    "lint": "corepack pnpm --dir apps/api lint",
    "lint:fix": "corepack pnpm --dir apps/api lint:fix",
    "typecheck": "corepack pnpm --dir apps/api typecheck",
    "build": "corepack pnpm --dir apps/api build",
    "build:web": "corepack pnpm --filter @tmh/web build",
    "typecheck:web": "corepack pnpm --filter @tmh/web typecheck",
    "test:unit": "corepack pnpm --dir apps/api test -- --runInBand",
    "test:e2e:db:up": "corepack pnpm --dir apps/api test:e2e:db:up",
    "test:e2e:db:down": "corepack pnpm --dir apps/api test:e2e:db:down",
    "db:migrate:test": "corepack pnpm --dir apps/api db:migrate:test",
    "db:migrate:deploy": "corepack pnpm --dir apps/api db:migrate:deploy",
    "test:e2e": "corepack pnpm --dir apps/api test:e2e",
    "test:e2e:local": "npm run test:e2e:db:up && npm run db:migrate:test && npm run test:e2e",
    "docker:api:up": "docker compose up --build api",
    "docker:api:down": "docker compose down -v",
    "verify": "npm run lint && npm run typecheck && npm run build && npm run test:unit",
    "verify:full": "npm run verify && npm run test:e2e:local"
  }
}
